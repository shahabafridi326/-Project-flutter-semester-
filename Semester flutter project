// Profile Screen
class ProfileScreen extends StatelessWidget {
  const ProfileScreen({super.key});

  Widget infoTile(String title, String value) {
    return Card(
      child: ListTile(
        title: Text(title),
        subtitle: Text(value),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text("Profile"),
      ),
      body: ListView(
        padding: const EdgeInsets.all(10),
        children: [
          infoTile("Name", "Shahab Ud Din"),
          infoTile("Registration No", "FU-CS-2024-73"),
          infoTile("Semester", "4th"),
          infoTile("Section", "B"),
          infoTile("Department", "Computer Science"),
          infoTile("University", "FATA University"),
          infoTile("Course", "Mobile Application"),
        ],
      ),
    );
  }
}

